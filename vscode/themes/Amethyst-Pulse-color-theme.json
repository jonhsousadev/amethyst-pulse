{
  "name": "Amethyst Pulse",
  "type": "dark",
  "colors": {
    // --- UI: TITLE BAR ---
    "titleBar.activeBackground": "#1A1620",
    "titleBar.activeForeground": "#EEE8D5",
    "titleBar.inactiveBackground": "#1A1620",
    "titleBar.inactiveForeground": "#6B6080",
    "titleBar.border": "#2D283A",

    // --- UI: TABS ---
    "editorGroupHeader.tabsBackground": "#1A1620",
    "tab.activeBackground": "#1E1A24",
    "tab.activeForeground": "#EEE8D5",
    "tab.inactiveBackground": "#1A1620",
    "tab.inactiveForeground": "#6B6080",
    "tab.activeBorderTop": "#BB9AF7",
    "tab.border": "#2D283A",

    // --- UI: STATUS BAR ---
    "statusBar.background": "#1A1620",
    "statusBar.foreground": "#EEE8D5",
    "statusBar.border": "#312A3D",
    "statusBarItem.hoverBackground": "#282330",

    // --- UI: COMMAND CENTER ---
    "commandCenter.background": "#282330",
    "commandCenter.border": "#4A3B5C",
    "commandCenter.foreground": "#EEE8D5",

    // --- UI: INPUTS, DROPDOWNS & SETTINGS ---
    "input.background": "#282330",
    "input.foreground": "#EEE8D5",
    "input.border": "#4A3B5C",
    "input.placeholderForeground": "#6B6080",
    "dropdown.background": "#282330",
    "dropdown.border": "#4A3B5C",
    "dropdown.foreground": "#EEE8D5",
    "settings.headerForeground": "#BB9AF7",
    "settings.modifiedItemIndicator": "#BB9AF7",

    // --- UI: BUTTONS & LISTS ---
    "button.background": "#BB9AF7",
    "button.foreground": "#000000",
    "button.hoverBackground": "#A370F0",
    "list.hoverBackground": "#282330",
    "list.activeSelectionBackground": "#2D2438",
    "list.activeSelectionForeground": "#BB9AF7",
    "list.inactiveSelectionBackground": "#231D2B",
    "list.focusBackground": "#3D334D",

    // --- UI: SIDEBAR & TREE ---
    "sideBar.background": "#1A1620",
    "sideBar.foreground": "#EEE8D5",
    "sideBar.border": "#2D283A",
    "sideBarSectionHeader.background": "#1A1620",
    "sideBarSectionHeader.foreground": "#BB9AF7",
    "tree.indentGuidesStroke": "#4A3B5C",

    // --- UI: ACTIVITY BAR ---
    "activityBar.background": "#1A1620",
    "activityBar.foreground": "#BB9AF7",
    "activityBar.border": "#2D283A",

    // --- BADGES ---
    "activityBarBadge.background": "#FFB347",
    "activityBarBadge.foreground": "#000000",
    "badge.background": "#BB9AF7",
    "badge.foreground": "#000000",

    // --- EDITOR ---
    "editor.background": "#1E1A24",
    "editor.foreground": "#EEE8D5",
    "editorCursor.foreground": "#FF9E64",
    "editor.lineHighlightBackground": "#282330",
    "editor.selectionBackground": "#4a3b5c80",
    "editorIndentGuide.background": "#312A3D",
    "editorIndentGuide.activeBackground": "#BB9AF7",
    "editorLineNumber.activeForeground": "#BB9AF7",
    "editorLineNumber.foreground": "#4A3B5C",
    "breadcrumb.foreground": "#6B6080",
    "breadcrumb.activeSelectionForeground": "#EEE8D5",
    "editorLightBulb.foreground": "#FF9E64",
    "minimap.border": "#2D283A",

    // --- EDITOR GROUPS & PANELS ---
    "editorGroup.border": "#2D283A",
    "editorGroupHeader.border": "#2D283A",
    "editorGroup.dropBackground": "#2D283A80",
    "panel.border": "#2D283A",
    "panel.section.border": "#2D283A",
    "panel.section.header.background": "#1A1620",

    // --- TERMINAL ---
    "terminal.background": "#1E1A24",
    "terminal.foreground": "#EEE8D5",
    "terminalCursor.foreground": "#FF9E64",
    "terminal.ansiBlack": "#1A1620",
    "terminal.ansiBlue": "#7AA2F7",
    "terminal.ansiCyan": "#B4F9F8",
    "terminal.ansiGreen": "#9ECE6A",
    "terminal.ansiMagenta": "#BB9AF7",
    "terminal.ansiRed": "#F7768E",
    "terminal.ansiWhite": "#EEE8D5",
    "terminal.ansiYellow": "#FF9E64",
    "terminal.ansiBrightBlack": "#4A3B5C",
    "terminal.ansiBrightBlue": "#7AA2F7",
    "terminal.ansiBrightCyan": "#B4F9F8",
    "terminal.ansiBrightGreen": "#9ECE6A",
    "terminal.ansiBrightMagenta": "#BB9AF7",
    "terminal.ansiBrightRed": "#F7768E",
    "terminal.ansiBrightWhite": "#EEE8D5",
    "terminal.ansiBrightYellow": "#FF9E64"
    ,
    // --- CURRENT SCOPE HIGHLIGHT ---
    "editor.selectionHighlightBackground": "#3D334D80",
    "editor.selectionHighlightBorder": "#BB9AF7"
  },
  "tokenColors": [
    {
      "name": "Control Structures (if, else, for, while, return)",
      "scope": [
        "keyword.control",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#FF9E64",
        "fontStyle": "italic bold"
      }
    },
    // --- OPERATORS ---
    {
      "name": "Comparison Operators (==, ===, !=, !==, >, <, >=, <=)",
      "scope": [
        "keyword.operator.comparison"
      ],
      "settings": {
        "foreground": "#FFB347",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Logical Operators (!, &&, ||)",
      "scope": [
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#9ECE6A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Assignment Operators (=, +=, -=, etc.)",
      "scope": [
        "keyword.operator.assignment"
      ],
      "settings": {
        "foreground": "#7AA2F7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Other Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#F7768E"
      }
    },
    // --- .env files ---
    {
      "name": ".env Keys",
      "scope": [
        "variable.other.env",
        "support.type.property-name.env"
      ],
      "settings": {
        "foreground": "#BB9AF7",
        "fontStyle": "bold"
      }
    },
    {
      "name": ".env Equal Sign",
      "scope": [
        "keyword.operator.assignment.env"
      ],
      "settings": {
        "foreground": "#7AA2F7"
      }
    },
    {
      "name": ".env Values",
      "scope": [
        "string.unquoted.env",
        "constant.other.env"
      ],
      "settings": {
        "foreground": "#FF9E64"
      }
    },
    {
      "name": ".env Comments",
      "scope": [
        "comment.line.number-sign.env"
      ],
      "settings": {
        "foreground": "#6B6080",
        "fontStyle": "italic"
      }
    },
    // --- SQL ---
    {
      "name": "SQL Keywords",
      "scope": [
        "keyword.other.DML.sql",
        "keyword.other.DDL.sql",
        "keyword.other.TCL.sql",
        "keyword.other.DCL.sql",
        "keyword.control.sql"
      ],
      "settings": {
        "foreground": "#BB9AF7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "SQL Functions",
      "scope": [
        "support.function.sql"
      ],
      "settings": {
        "foreground": "#7AA2F7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "SQL Strings",
      "scope": [
        "string.quoted.single.sql",
        "string.quoted.double.sql"
      ],
      "settings": {
        "foreground": "#FF9E64"
      }
    },
    {
      "name": "SQL Numbers",
      "scope": [
        "constant.numeric.sql"
      ],
      "settings": {
        "foreground": "#B4F9F8"
      }
    },
    {
      "name": "SQL Comments",
      "scope": [
        "comment.line.double-dash.sql",
        "comment.block.sql"
      ],
      "settings": {
        "foreground": "#6B6080",
        "fontStyle": "italic"
      }
    },
    // --- MongoDB ---
    {
      "name": "MongoDB Operators",
      "scope": [
        "variable.other.mongodb.operator",
        "support.type.property-name.mongodb"
      ],
      "settings": {
        "foreground": "#BB9AF7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "MongoDB Functions",
      "scope": [
        "support.function.mongodb"
      ],
      "settings": {
        "foreground": "#7AA2F7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "MongoDB Strings",
      "scope": [
        "string.quoted.double.mongodb",
        "string.quoted.single.mongodb"
      ],
      "settings": {
        "foreground": "#FF9E64"
      }
    },
    {
      "name": "MongoDB Numbers",
      "scope": [
        "constant.numeric.mongodb"
      ],
      "settings": {
        "foreground": "#B4F9F8"
      }
    },
    {
      "name": "MongoDB Comments",
      "scope": [
        "comment.line.double-slash.mongodb",
        "comment.block.mongodb"
      ],
      "settings": {
        "foreground": "#6B6080",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Declarations (const, let, var) - Amethyst",
      "scope": [
        "storage.type",
        "storage.modifier",
        "keyword.declaration.js",
        "keyword.declaration.ts"
      ],
      "settings": {
        "foreground": "#BB9AF7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Import / Export / From keywords",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.default",
        "keyword.other.import",
        "keyword.other.export",
        "keyword.other.from"
      ],
      "settings": {
        "foreground": "#BB9AF7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Import wildcard (* in import * from)",
      "scope": [
        "constant.language.import-export-all",
        "constant.language.import-export-all.js",
        "constant.language.import-export-all.ts",
        "keyword.operator.module",
        "storage.type.namespace.wildcard"
      ],
      "settings": {
        "foreground": "#F7768E",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Template Literal Interpolation Punctuation (${ and })",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.section.embedded.begin",
        "punctuation.section.embedded.end"
      ],
      "settings": {
        "foreground": "#F7768E",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Template Literal Interpolated Expression (variable inside ${})",
      "scope": [
        "meta.template.expression",
        "meta.embedded.expression"
      ],
      "settings": {
        "foreground": "#E0AFAF"
      }
    },
    {
      "name": "Object Properties & CSS Variables",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name.css",
        "entity.other.attribute-name.variable.css",
        "meta.property.object.js",
        "variable.other.property.js"
      ],
      "settings": {
        "foreground": "#B4F9F8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Objects - PERSON.name",
      "scope": [
        "variable.other.object",
        "variable.other.readwrite.alias"
      ],
      "settings": {
        "foreground": "#EEE8D5"
      }
    },
    {
      "name": "Function Invocations - func()",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#7AA2F7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#E0AFAF"
      }
    },
    {
      "name": "HTML/XML Tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#7AA2F7"
      }
    },
    {
      "name": "HTML/CSS Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#BB9AF7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#FF9E64"
      }
    },
    {
      "name": "CSS Values, Constants & Numbers",
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant.property-value.css",
        "support.constant.color.w3c-standard-color-name.css",
        "variable.parameter.url.css"
      ],
      "settings": {
        "foreground": "#FF9E64"
      }
    },
    {
      "name": "CSS IDs & Classes",
      "scope": [
        "entity.other.attribute-name.id",
        "entity.other.attribute-name.class"
      ],
      "settings": {
        "foreground": "#FF9E64",
        "fontStyle": "bold"
      }
    },
    {
      "name": "JSON Keys",
      "scope": [
        "support.type.property-name.json",
        "meta.mapping.key.json"
      ],
      "settings": {
        "foreground": "#B4F9F8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "JSON Values",
      "scope": [
        "string.json",
        "constant.numeric.json",
        "constant.language.json"
      ],
      "settings": {
        "foreground": "#FFB48A"
      }
    },
    {
      "name": "Comments (Muted Purple)",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6B6080",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown - Headings (Purple)",
      "scope": [
        "markup.heading",
        "markup.heading.markdown",
        "markup.heading.marker"
      ],
      "settings": {
        "foreground": "#BB9AF7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown - Heading Punctuation (Dark Blue)",
      "scope": [
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#4A3B5C"
      }
    },
    {
      "name": "Markdown - Bold Text (Blue)",
      "scope": [
        "markup.bold",
        "markup.bold.markdown"
      ],
      "settings": {
        "foreground": "#7AA2F7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown - Italic Text (Orange)",
      "scope": [
        "markup.italic",
        "markup.italic.markdown"
      ],
      "settings": {
        "foreground": "#FF9E64",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown - List Markers & Numbers (Dark Blue)",
      "scope": [
        "markup.list.bullet",
        "markup.list.markdown",
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#4A3B5C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown - List Content (Cream)",
      "scope": [
        "markup.list"
      ],
      "settings": {
        "foreground": "#EEE8D5"
      }
    },
    {
      "name": "Markdown - Links & URLs",
      "scope": [
        "markup.underline.link",
        "markup.link",
        "string.link"
      ],
      "settings": {
        "foreground": "#B4F9F8",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown - Inline Code & Code Blocks",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#9ECE6A"
      }
    },
    {
      "name": "Markdown - Blockquote & Horizontal Rule",
      "scope": [
        "markup.quote",
        "markup.other"
      ],
      "settings": {
        "foreground": "#6B6080",
        "fontStyle": "italic"
      }
    }
  ]
}
